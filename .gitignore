# AccessLint reports and cache
accesslint-reports/
.accesslint-cache/

# Jira integration credentials (local only - never commit)
.jira-config

# Cursor IDE local rules
.cursor/
.claude/settings.local.json

# Environment files (local secrets - never commit)
.env
.env.local
.env*.local

# QAAtlas output (generated files)
qaatlas-output/
qaatlas-v2-report/

# Ledger artifacts (generated files - regenerate with `ledger update`)
artifacts/ledger/

# Ledger internal state (regenerated automatically)
.ledger/index.sqlite
.ledger/model.json
.ledger/last_update.json
.ledger/flows/flows-intent.yaml

# Ledger generated docs (regenerated with `ledger update`)
# Keep: INDEX.md, SYSTEM_MAP.md (contain MANUAL sections)
# Keep: FLOWS/*.md (human-authored flow documentation)
# Keep: FEEDBACK_*.md (human feedback)
docs/ledger/CONTRACTS/
docs/ledger/DELTAS/
docs/ledger/ANALYSIS.md
docs/ledger/OPEN_QUESTIONS.md
docs/ledger/VERIFICATION.md

# Tools binaries (downloaded, not committed)
tools/bin/

# Reports (generated during validation, can be large)
reports/

# Spec documents (generated by ledger spec build)
docs/spec/
